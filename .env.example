# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://voc:voc_dev_password@localhost:5432/voc_intelligence

# Groq — extraction, enrichment, RAG, and embeddings (Phase 3+)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1_5

# Hugging Face — Pipeline 1 (set HF_DATASET_ID when you have the dataset ID)
HF_TOKEN=
HF_DATASET_ID=
HF_DATASET_SPLIT=train

# Scrape allowlist (comma-separated domains)
SCRAPE_ALLOWLIST=apps.apple.com,play.google.com,quora.com,twitter.com,x.com,reddit.com

# Guardrail thresholds
MIN_RETRIEVAL_SCORE=0.72
MIN_EVIDENCE_ITEMS=3
QUOTE_MATCH_THRESHOLD=0.90
EXTRACTION_GROUNDING_THRESHOLD=0.85
LLM_TEMPERATURE=0

# Optional: protect n8n → app webhooks
N8N_WEBHOOK_SECRET=

# Optional: for server-side health fetch on homepage
NEXT_PUBLIC_APP_URL=http://localhost:3000
