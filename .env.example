# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://voc:voc_dev_password@localhost:5432/voc_intelligence

# Groq — insights analysis only (RAG / Ask)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local embeddings (Transformers.js)
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

RAG_RETRIEVE_POOL=40
RAG_TOP_K=12

# Live scrape — App Store + Play Store only
SCRAPE_ALLOWLIST=apps.apple.com,play.google.com
SCRAPE_USER_AGENT=VoC-Intelligence/1.0 (graduation project; +https://localhost)
SCRAPE_MAX_PER_SOURCE=100

MIN_RETRIEVAL_SCORE=0.38
MIN_EVIDENCE_ITEMS=3
QUOTE_MATCH_THRESHOLD=0.90
EXTRACTION_GROUNDING_THRESHOLD=0.85
LLM_TEMPERATURE=0

N8N_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3001
